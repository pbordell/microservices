<?xml version="1.0" encoding="UTF-8" ?>
<!-- 1. Actualizado el DTD para que sea compatible con Struts 6.x sin dar fallos de parseo -->
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 6.0.0//EN"
        "http://apache.org">
<struts>
    <constant name="struts.devMode" value="true" />
    <constant name="struts.mapper.action.prefix.enabled" value="true" />

    <package name="reports" namespace="/reports" extends="struts-default" >

        <interceptors>
            <interceptor-stack name="appDefault">
                <interceptor-ref name="paramsPrepareParamsStack">
                    <param name="exception.logEnabled">true</param>
                    <param name="exception.logLevel">ERROR</param>
                    <param name="params.excludeParams">dojo\..*,^struts\..*,^session\..*,^request\..*,^application\..*,^servlet(Request|Response)\..*,parameters\...*,submit</param>
                </interceptor-ref>
            </interceptor-stack>
        </interceptors>

        <default-interceptor-ref name="appDefault" />

        <action name="generateReport" class="com.pbs.report.action.ReportAction" method="exportInExcel">
            <result  name="success"  type="stream">
                <param name="contentType">application/vnd.ms-excel</param>
                <param name="inputName">inputStream</param>
                <param name="contentDisposition">attachment;filename="crudList.xls"</param>
                <param name="bufferSize">4096</param>
            </result>
        </action>

    </package>
</struts>
